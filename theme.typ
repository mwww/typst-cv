// ── Fonts ────────────────────────────────────────────────────────────────────
// #let font-name = ("Helvetica", "VCR OSD Mono")
#let font-name = ("VCR OSD Mono")
#let font      = ("Atkinson Hyperlegible Next", "Arial", "Liberation Sans")
#let font-mono = ("JetBrains Mono", "Menlo", "Courier New")

// ── Type scale ───────────────────────────────────────────────────────────────
#let size-name    = 40pt
#let size-section =  7.5pt
#let size-body    = 10pt
#let size-meta    =  9pt
#let size-footer  =  7.5pt

// ── Colors ───────────────────────────────────────────────────────────────────
#let color-body   = luma(30)   // #1e1e1e — near-black, softer than pure black
#let color-footer = luma(130)  // mid-gray — subtle, clearly secondary

// ── Summary ──────────────────────────────────────────────────────────────────
#let size-summary   = 10.5pt
#let gap-after-summary = 1em

// ── Strokes ──────────────────────────────────────────────────────────────────
#let stroke-heavy = 1.5pt + black
#let stroke-light = 0.4pt + black

// ── Spacing ──────────────────────────────────────────────────────────────────
#let gap-after-header   = 1.6em
#let gap-before-section = 1.4em
#let gap-after-section  = 0.55em
#let gap-between-entries = 0.85em
#let gap-between-details = 0.4em
